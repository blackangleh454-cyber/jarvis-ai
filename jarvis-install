#!/bin/bash

# JARVIS Skill Installer Command Wrapper
# Usage: ./jarvis-install install <package>
#        ./jarvis-install list

SKILL_HANDLER="/home/mirza/Desktop/J.A.R.V.I.S/skills/skill-installer/handler.py"

if [ "$1" == "install" ]; then
    shift
    python3 "$SKILL_HANDLER" install "$@"
elif [ "$1" == "list" ]; then
    python3 "$SKILL_HANDLER" list
elif [ "$1" == "remove" ]; then
    shift
    python3 "$SKILL_HANDLER" remove "$@"
elif [ "$1" == "search" ]; then
    shift
    python3 "$SKILL_HANDLER" search "$@"
else
    echo "JARVIS Skill Installer"
    echo "======================"
    echo ""
    echo "Usage:"
    echo "  $0 install <package>   Install skill from npm"
    echo "  $0 list               List all skills"
    echo "  $0 remove <skill>    Remove a skill"
    echo "  $0 search <query>    Search for skills"
    echo ""
    echo "Examples:"
    echo "  $0 install clawhub@latest install guoqiao/dl"
    echo "  $0 install https://github.com/user/repo"
    echo "  $0 list"
fi
